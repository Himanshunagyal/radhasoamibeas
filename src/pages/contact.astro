---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact" description="Contact the RSSB Devotional website team.">
  <div class="bg-rssb-red text-white py-10 px-4 text-center">
    <h1 class="font-serif text-3xl font-bold">Contact</h1>
    <p class="text-red-200 mt-2">Questions, suggestions, or corrections? Reach out.</p>
  </div>
  <section class="py-10 px-4 max-w-xl mx-auto">
    <div class="bg-white rounded-2xl border border-red-200 p-8">
      <p class="text-gray-600 text-sm mb-6">This is an independent devotional website. For official RSSB inquiries, please visit <a href="https://www.rssb.org" target="_blank" class="text-rssb-red hover:underline">rssb.org</a>.</p>
      <form action="https://formspree.io/f/your-form-id" method="POST" class="space-y-4">
        <div>
          <label class="block text-sm font-semibold text-rssb-red mb-1">Your Name</label>
          <input type="text" name="name" required class="w-full border border-gray-300 rounded-lg px-4 py-2 text-sm focus:outline-none focus:border-rssb-red" />
        </div>
        <div>
          <label class="block text-sm font-semibold text-rssb-red mb-1">Email</label>
          <input type="email" name="email" required class="w-full border border-gray-300 rounded-lg px-4 py-2 text-sm focus:outline-none focus:border-rssb-red" />
        </div>
        <div>
          <label class="block text-sm font-semibold text-rssb-red mb-1">Message</label>
          <textarea name="message" rows="5" required class="w-full border border-gray-300 rounded-lg px-4 py-2 text-sm focus:outline-none focus:border-rssb-red resize-none"></textarea>
        </div>
        <button type="submit" class="w-full bg-rssb-red text-white font-bold py-3 rounded-full hover:bg-rssb-redDark transition">
          Send Message 🙏
        </button>
      </form>
    </div>
  </section>
</Layout>
